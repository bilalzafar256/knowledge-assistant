# ============================================================
# Company Knowledge Assistant — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Database (Neon Postgres + pgvector) ─────────────────────
# Get from: https://neon.tech → Project Settings → Connection String
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── OpenAI ──────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ── Cohere (optional — RAG reranker) ─────────────────────────
# If set, the chat pipeline uses Cohere Rerank 3.5 instead of gpt-4o-mini
# for the final reranker step. Falls back automatically if absent.
# Get from: https://dashboard.cohere.com/api-keys
# COHERE_API_KEY="..."

# ── Clerk Authentication ─────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect URLs (keep these as-is for local dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# ── Arcjet Security ──────────────────────────────────────────
# Get from: https://app.arcjet.com → Sites → API Keys
ARCJET_KEY="ajkey_..."

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Inngest (background job queue) ──────────────────────────
# Required in production for reliable document ingestion with retries.
# Without these, ingestion runs inline inside the API response (55 s timeout).
# Get from: https://app.inngest.com → Select app → Keys
INNGEST_EVENT_KEY="..."
INNGEST_SIGNING_KEY="signkey-..."
#
# Vercel Deployment Protection bypass (required if your Vercel project has
# password or SSO protection enabled, so Inngest can reach /api/inngest).
# 1. Set VERCEL_AUTOMATION_BYPASS_SECRET in your Vercel project env vars.
# 2. Copy that same secret into the Inngest dashboard:
#    app.inngest.com → Your App → Settings → Deployment Protection Key
# VERCEL_AUTOMATION_BYPASS_SECRET="..."

# ── Vercel (auto-populated on Vercel deployments) ────────────
# VERCEL_URL is set automatically — do not set manually in production
# NEXT_PUBLIC_VERCEL_URL="${VERCEL_URL}"

# ── Observability — Axiom (logs + OpenTelemetry traces) ─────
# If unset, logs fall back to console and traces are not exported.
# In production, set these on Vercel as Sensitive env vars.
#
# 1. AXIOM_TOKEN: app.axiom.co → Settings → API tokens → Create (ingest scope)
# 2. AXIOM_DATASET: name of the dataset created in Axiom (e.g. "knowledge-assistant")
# 3. AXIOM_HOST: optional — default api.axiom.co (use api.eu.axiom.co for EU)
AXIOM_TOKEN="xaat-..."
AXIOM_DATASET="knowledge-assistant"
# AXIOM_HOST="api.axiom.co"

# ── Eval harness — Open RAG Benchmark ───────────────────────
# Stable tenant key for the Vectara Open RAG Benchmark corpus
# (`pnpm eval:ragbench:*`). NOT a real Clerk user — just an isolation
# label so benchmark docs don't mix with the regular eval corpus.
OPEN_RAGBENCH_USER_ID="user_open_ragbench_eval"

# ── Telegram → GitHub PR bot ─────────────────────────────────
# Powers /api/telegram/webhook. Send a Telegram message → Claude Code
# runs in GitHub Actions → PR opens automatically.
#
# 1. TELEGRAM_BOT_TOKEN: from @BotFather after /newbot
# 2. TELEGRAM_CHAT_ID:   your numeric chat id (see getUpdates JSON)
# 3. TELEGRAM_WEBHOOK_SECRET: random string, e.g. `openssl rand -hex 32`
#    Must match the secret_token used when registering the webhook.
# 4. GITHUB_PAT: fine-grained PAT with Contents:read/write on this repo
# 5. GITHUB_REPO: owner/name — defaults to bilalzafar256/knowledge-assistant
TELEGRAM_BOT_TOKEN="123456:ABC..."
TELEGRAM_CHAT_ID="123456789"
TELEGRAM_WEBHOOK_SECRET="replace-with-random-string"
GITHUB_PAT="github_pat_..."
GITHUB_REPO="bilalzafar256/knowledge-assistant"
